                <VoltageAxis> 0</VoltageAxis>
                <TemperatureAxis> 25</TemperatureAxis>
                <Energy scale="1">
                    <Temperature>
                        <Voltage> 0</Voltage>
                    </Temperature>
                </Energy>
            </TurnOffLoss>
